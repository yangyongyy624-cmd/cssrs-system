<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.cssrs.system</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>PROJECT_DIR/scripts/start-local.sh</string>
        <string>--daemon</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PROJECT_DIR</key>
        <string>/Users/zujing/Developer/cssrs-system</string>
    </dict>
    <key>WorkingDirectory</key>
    <string>/Users/zujing/Developer/cssrs-system</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>ThrottleInterval</key>
    <integer>30</integer>
    <key>StandardOutPath</key>
    <string>/Users/zujing/Developer/cssrs-system/logs/launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/zujing/Developer/cssrs-system/logs/launchd.err.log</string>
</dict>
</plist>
