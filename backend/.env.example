# C-SSRS Backend Configuration
# Copy to .env and fill in actual values

# Server settings
HOST=0.0.0.0
PORT=8000

# Cloud Gateway URL (for QR codes and patient links)
# Example: http://82.156.238.242:8888
CLOUD_GATEWAY_URL=http://YOUR_SERVER:8888

# Database
DB_PATH=./cssrs.db

# Cloud Gateway (for cloud deployment)
CLOUD_MODE=0
MACMINI_URL=http://127.0.0.1:8000
